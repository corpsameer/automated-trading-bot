APP_NAME=telegram_coindcx_automation
APP_ENV=local
APP_MODE=capture
LOG_LEVEL=INFO

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=telegram_coindcx_automation
DB_USER=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

TELEGRAM_API_ID=
TELEGRAM_API_HASH=
TELEGRAM_PHONE=
TELEGRAM_SESSION_NAME=telegram_coindcx_session

COINDCX_API_KEY=
COINDCX_API_SECRET=
COINDCX_BASE_URL=https://api.coindcx.com

DEFAULT_SIGNAL_MAX_AGE_SECONDS=60
DEFAULT_MAX_OPEN_TRADES=1
DEFAULT_MAX_LEVERAGE=5
DEFAULT_RISK_PER_TRADE=100
KILL_SWITCH_ENABLED=true
